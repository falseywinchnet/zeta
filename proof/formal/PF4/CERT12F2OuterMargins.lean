theorem f2MarginOuterCoeff_const_floor : ∀ j ∈ Finset.range (6 + 1), 993511000 ≤ f2MarginOuterCoeff j 0 := by
  intro j hj
  simp only [Finset.mem_range] at hj
  interval_cases j <;> norm_num [f2MarginOuterCoeff]

theorem f2MarginOuterCoeff_nonneg : ∀ j ∈ Finset.range (6 + 1), ∀ k ∈ Finset.range (12 + 1), 0 ≤ f2MarginOuterCoeff j k := by
  intro j hj k hk
  simp only [Finset.mem_range] at hj hk
  interval_cases j <;> interval_cases k <;> norm_num [f2MarginOuterCoeff]

theorem f2MarginOuter_representation (v z : ℝ) :
    f2MarginOuterPolynomial (z + 5) (v / 3000000) =
      PF4.CERT12Inequalities.bernsteinHalfstripEval 6 12 f2MarginOuterCoeff v z := by
  norm_num [f2MarginOuterPolynomial, PF4.CERT12Inequalities.bernsteinHalfstripEval,
    f2MarginOuterCoeff, PF4.CERT12Inequalities.bernsteinBasis_eq, Nat.choose,
    Finset.sum_range_succ]
  ring

theorem f2MarginOuter_pos {v z : ℝ} (hv0 : 0 ≤ v) (hv1 : v ≤ 1) (hz : 0 ≤ z) :
    0 < f2MarginOuterPolynomial (z + 5) (v / 3000000) := by
  rw [f2MarginOuter_representation]
  exact PF4.CERT12Inequalities.bernsteinHalfstripEval_pos (by norm_num : (0 : ℚ) < 993511000) hv0 hv1 hz f2MarginOuterCoeff_const_floor f2MarginOuterCoeff_nonneg

theorem f2MarginOuter_region_pos {x y : ℝ}
    (hx : (5 : ℝ) ≤ x) (hy0 : 0 ≤ y) (hy1 : y ≤ 1 / 3000000) :
    0 < f2MarginOuterPolynomial x y := by
  let v := y / (1 / 3000000)
  let z := x - 5
  have hv0 : 0 ≤ v := by dsimp [v]; positivity
  have hv1 : v ≤ 1 := by
    dsimp [v]
    rw [div_le_one (by norm_num : (0 : ℝ) < 1 / 3000000)]
    exact hy1
  have hz : 0 ≤ z := by dsimp [z]; linarith
  have h := f2MarginOuter_pos hv0 hv1 hz
  dsimp [v, z] at h
  convert h using 1 <;> field_simp <;> ring_nf

theorem f2MarginCore_region_pos {x y : ℝ}
    (hx : (5 : ℝ) ≤ x) (hy0 : 0 ≤ y) (hy1 : y ≤ 1 / 3000000) :
    0 < PF4.CERT12Inequalities.Generated.f2MarginCorePolynomial x y := by
  have h := f2MarginOuter_region_pos hx hy0 hy1
  simpa [PF4.CERT12Inequalities.Generated.f2MarginCorePolynomial,
    f2MarginOuterPolynomial] using h

